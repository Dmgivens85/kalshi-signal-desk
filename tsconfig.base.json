{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@kalshi/shared-ts": ["packages/shared-ts/src"],
      "@kalshi/design-system": ["packages/design-system/src"],
      "@kalshi/strategy-sdk": ["packages/strategy-sdk/src"],
      "@kalshi/sdk": ["packages/typescript-sdk/src"],
      "@kalshi/config/*": ["packages/config/*"]
    }
  }
}
